		MiniBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
		MiniBtn.TextSize = 13
		MiniBtn.AutoButtonColor = false
		MiniBtn.BorderSizePixel = 0

		local MiniCorner = Instance.new("UICorner")
		MiniCorner.CornerRadius = UDim.new(0, 6)
		MiniCorner.Parent = MiniBtn

		local function AnimateClick(btn, originalColor)
			local tw = TweenService:Create(btn, TweenInfo.new(0.1), {
				BackgroundColor3 = Color3.fromRGB(30, 255, 180)
			})
			tw:Play()
			tw.Completed:Wait()
			TweenService:Create(btn, TweenInfo.new(0.2), { BackgroundColor3 = originalColor }):Play()
		end

		FullBtn.MouseEnter:Connect(function()
			TweenService:Create(FullBtn, TweenInfo.new(0.15), { BackgroundColor3 = Color3.fromRGB(38, 50, 74) }):Play()
		end)
		FullBtn.MouseLeave:Connect(function()
			TweenService:Create(FullBtn, TweenInfo.new(0.15), { BackgroundColor3 = Color3.fromRGB(28, 36, 54) }):Play()
		end)
		FullBtn.MouseButton1Click:Connect(function()
			AnimateClick(FullBtn, Color3.fromRGB(28, 36, 54))
			Callback()
		end)

		MiniBtn.MouseEnter:Connect(function()
			TweenService:Create(MiniBtn, TweenInfo.new(0.15), { BackgroundColor3 = Color3.fromRGB(45, 52, 70) }):Play()
		end)
		MiniBtn.MouseLeave:Connect(function()
			TweenService:Create(MiniBtn, TweenInfo.new(0.15), { BackgroundColor3 = Color3.fromRGB(35, 40, 55) }):Play()
		end)
		MiniBtn.MouseButton1Click:Connect(function()
			AnimateClick(MiniBtn, Color3.fromRGB(35, 40, 55))
			Callback()
		end)

		function ButtonObj:SetText(NewText: string)
			MiniBtn.Text = NewText
			FullBtn.Text = NewText
		end

		function ButtonObj:SetEnabled(Enabled: boolean)
			MiniBtn.Active = Enabled
			FullBtn.Active = Enabled
			local t = if Enabled then 0 else 0.5
			MiniBtn.TextTransparency = t
			FullBtn.TextTransparency = t
		end

		return ButtonObj
	end

	return WindowObj
end

